#!/usr/bin/env bash
set -euo pipefail

# 确保 cargo 可用（某些 Git 环境的 PATH 不包含 .cargo/bin）
export PATH="$HOME/.cargo/bin:$PATH"

echo "[pre-commit] 正在检查 Rust 代码格式 (cargo fmt --check)..."

# 只检查本次提交的 .rs 文件（比全项目检查更快）
staged_rs_files=$(git diff --cached --name-only --diff-filter=ACM | grep '\.rs$' || true)

if [ -n "$staged_rs_files" ]; then
    echo "[pre-commit] 检查文件：$staged_rs_files"

    if ! cargo fmt --check -- $staged_rs_files 2>&1; then
        echo ""
        echo "[pre-commit] 代码格式检查失败！请运行："
        echo "  cargo fmt"
        exit 1
    fi
else
    echo "[pre-commit] 没有需要检查的 Rust 文件，跳过。"
fi

echo "[pre-commit] ✅ 格式检查通过。"