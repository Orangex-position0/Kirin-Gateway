#!/usr/bin/env bash
# pre-push hook: YAML 语法校验 + 本地检查（与 CI 一致）
# 任一检查失败则阻止推送

set -euo pipefail

# 颜色输出
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# 1. CI workflow YAML 语法校验（可选，需要 wrkflw）
if command -v wrkflw &> /dev/null; then
    echo -e "${GREEN}[pre-push] 正在校验 CI workflow 配置...${NC}"
    if ! wrkflw validate; then
        echo -e "\n${RED}[pre-push] ❌ CI workflow 校验失败！请修复后再推送。${NC}"
        exit 1
    fi
    echo "[pre-push] ✅ Workflow 语法校验通过"
else
    echo -e "${YELLOW}[pre-push] ⚠️  未安装 wrkflw，已跳过 YAML 语法校验。安装命令：cargo install wrkflw${NC}"
fi

# 2. 格式检查（对应 ci.yml 的 fmt job）
echo ""
echo "[pre-push] 正在检查代码格式 (cargo fmt --check)..."
if ! cargo fmt --check 2>&1; then
    echo -e "\n${RED}[pre-push] ❌ 格式错误！请执行 cargo fmt 修复${NC}"
    exit 1
fi
echo "[pre-push] ✅ 格式检查通过"

# 3. Clippy 检查（对应 ci.yml 的 clippy job）
echo ""
echo "[pre-push] 正在运行 Clippy 检查..."
if ! cargo clippy --all-targets -- -D warnings 2>&1; then
    echo -e "\n${RED}[pre-push] ❌ Clippy 检查失败！${NC}"
    exit 1
fi
echo "[pre-push] ✅ Clippy 检查通过"

# 4. 测试（对应 ci.yml 的 test job）
echo ""
echo "[pre-push] 正在运行测试..."
if ! cargo test --all-targets -- --test-threads=1 2>&1; then
    echo -e "\n${RED}[pre-push] ❌ 测试失败！${NC}"
    exit 1
fi
echo "[pre-push] ✅ 测试通过"

echo ""
echo -e "${GREEN}[pre-push] 🚀 所有检查通过，允许推送。${NC}"
